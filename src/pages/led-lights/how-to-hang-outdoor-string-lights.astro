---
import Article from '../../layouts/Article.astro';

const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: 'LED String Lights', url: '/led-lights' },
  { label: 'How to Hang String Lights', url: null },
];

const allCategoryArticles = [
  { title: 'How to Hang Outdoor String Lights', url: '/led-lights/how-to-hang-outdoor-string-lights', date: '2025-01-15' },
  { title: 'Best Outdoor String Lights 2025', url: '/led-lights/best-outdoor-string-lights-2025', date: '2025-03-01' },
];

const relatedArticles = [
  { title: 'Best Outdoor String Lights 2025', url: '/led-lights/best-outdoor-string-lights-2025', category: 'LED Lights' },
  { title: 'How to Hang Outdoor String Lights', url: '/led-lights/how-to-hang-outdoor-string-lights', category: 'LED Lights' },
];

const howtoSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Hang Outdoor String Lights Without Damaging Your House",
  "description": "5 damage-free methods to hang outdoor string lights. Guide wires, adhesive hooks, gutter clips, and zip ties. Tested on patios, decks, and yards.",
  "datePublished": "2025-01-15",
  "dateModified": "2025-03-15",
  "author": { "@type": "Organization", "name": "YardFavorites" },
  "publisher": { "@type": "Organization", "name": "YardFavorites", "url": "https://yardfavorites.com" },
  "step": [
    { "@type": "HowToStep", name: "Plan your layout", text: "Measure your space and mark hook positions before installing anything." },
    { "@type": "HowToStep", name: "Choose the right method", text: "Select based on your surface: guide wires for long spans, clips for gutters, adhesive hooks for smooth surfaces." },
    { "@type": "HowToStep", name: "Install mounting hardware", text: "Attach guide wires or hooks at each endpoint and every 2-3 feet for support." },
    { "@type": "HowToStep", name: "String the lights", text: "Lay lights along the wire, using cable ties to secure every 1-2 feet." },
    { "@type": "HowToStep", name: "Test and adjust", text: "Plug in and check for sag, hot spots, or loose sections." },
  ],
  "supply": [
    { "@type": "HowToSupply", name: "Guide wire or picture wire" },
    { "@type": "HowToSupply", name: "S-hooks or snap hooks" },
    { "@type": "HowToSupply", name: "Outdoor adhesive hooks (like 3M Command)" },
    { "@type": "HowToSupply", name: "Cable ties / zip ties" },
    { "@type": "HowToSupply", name: "Gutter clips (if applicable)" },
  ],
};

const keyStats = [
  { number: '0 holes', label: 'All 5 methods work without drilling' },
  { number: '$10-30', label: 'Total hardware cost for most methods' },
  { number: '2-3 ft', label: 'Optimal support spacing for sag prevention' },
];

const faqItems = [
  { q: 'How do I hang string lights on a patio without nails?', a: 'Use adhesive hooks (3M Command Outdoor) for smooth surfaces — they hold up to 3 lbs and remove cleanly. For gutters, use gutter clips that snap on without hardware. Neither method requires drilling or nails.' },
  { q: 'What is the best way to hang string lights over a large span?', a: 'Use a guide wire system: run stainless steel wire between two anchor points, then hang lights from the wire with S-hooks or zip ties. This supports the weight and prevents sagging.' },
  { q: 'How far apart should string light supports be?', a: 'For most string light sets, support every 2-3 feet. Without enough support, the lights will sag significantly. For heavy C9 bulbs, support every 18-24 inches.' },
  { q: 'Do string light hooks damage gutters?', a: 'Gutter clips designed for string lights snap onto the gutter lip without adhesives or screws, causing zero damage. Avoid hanging heavy loads from gutter spikes — that causes damage.' },
  { q: 'Can I leave outdoor string lights up year-round?', a: 'Quality outdoor-rated lights (IP65+) can stay up 12 months. Check your lights IP rating: IP44 handles light rain, IP65+ handles heavy rain and sun exposure.' },
  { q: 'How do I keep string lights from sagging?', a: 'Three things: (1) Use a guide wire to support weight; (2) Support every 2 feet, not just at endpoints; (3) Choose the right bulb weight — C9 bulbs are heavier and need more support.' },
];
---

<Article
  title="How to Hang Outdoor String Lights Without Damaging Your House — 5 Methods"
  description="5 damage-free methods to hang outdoor string lights. Guide wires, adhesive hooks, gutter clips, and more. Tested on real patios, decks, and yards."
