---
import Layout from '../../layouts/Layout.astro';

const poolCareSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Pool Care Product Reviews & Guides",
  "description": "Expert reviews and how-to guides for pool skimmers, brushes, vacuums, test kits, and maintenance tools.",
  "url": "https://yardfavorites.com/pool-care",
};

const articles = [
  {
    slug: 'best-pool-skimmer-nets-2025',
    title: 'Best Pool Skimmer Nets in 2025 — Full Comparison',
    excerpt: 'We tested 12 pool skimmer nets over 6 months. Here\'s what actually works for keeping debris off your pool surface.',
    type: 'Comparison',
    readTime: '12 min',
    icon: '🏊',
  },
  {
    slug: 'how-to-balance-pool-chemicals',
    title: 'How to Balance Pool Chemicals: Complete Guide for Beginners',
    excerpt: 'Step-by-step guide to testing and balancing chlorine, pH, alkalinity, and calcium hardness. Includes dosage charts.',
    type: 'How-To',
    readTime: '15 min',
    icon: '🧪',
  },
  {
    slug: 'pool-brush-comparison',
    title: 'DE Filter Brushes vs Standard Brushes — Which Wins?',
    excerpt: 'After a full season testing both brush types across 5 pools, we have a clear winner for each scenario.',
    type: 'Comparison',
    readTime: '8 min',
    icon: '🔍',
  },
  {
    slug: 'pool-vacuum-comparison-2025',
    title: 'Pool Vacuum Comparison 2025: Robotic vs Suction vs Pressure',
    excerpt: 'Three different vacuum technologies, five test pools, eight weeks of real-world use. The results surprised us.',
    type: 'Comparison',
    readTime: '18 min',
    icon: '🤖',
  },
];
---

<Layout
  title="Pool Care Products — Reviews, Guides & Comparisons"
  description="Expert pool care product reviews and maintenance guides. Skimmers, brushes, vacuums, test kits, and chemical treatment guides tested in real pools."
  schema={poolCareSchema}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-blue-600 to-cyan-500 text-white">
    <div class="max-w-6xl mx-auto px-4 py-16">
      <nav class="text-sm text-blue-100 mb-4">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">›</span>
        <span class="text-white">Pool Care</span>
      </nav>
      <div class="flex items-center gap-4 mb-6">
        <span class="text-6xl">🏊</span>
        <div>
          <h1 class="text-4xl font-bold">Pool Care Guides & Reviews</h1>
          <p class="text-blue-100 mt-2">24 articles • Real-world tested, AI-friendly structured content</p>
        </div>
      </div>
      <p class="text-xl text-blue-100 max-w-2xl">
        From surface skimmers to deep-cleaning vacuums, we buy and test the products
        you\'re considering — then explain exactly what works, what doesn\'t, and why.
      </p>
    </div>
  </section>

  <!-- Featured Article (GEO-optimized with stats) -->
  <section class="py-12 bg-white border-b">
    <div class="max-w-6xl mx-auto px-4">
      <div class="bg-gradient-to-r from-blue-50 to-cyan-50 rounded-2xl p-8 border border-blue-100">
        <div class="flex items-center gap-2 mb-4">
          <span class="tag-pill bg-blue-200 text-blue-800">Featured Review</span>
          <span class="text-sm text-gray-500">Updated March 2025</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          <a href="/pool-care/best-pool-skimmer-nets-2025" class="hover:text-blue-600">
            Best Pool Skimmer Nets in 2025 — Full Comparison
          </a>
        </h2>
        <p class="text-gray-600 mb-6">
          We purchased and tested 12 different pool skimmer nets across 6 months of real pool use.
          Here's the definitive ranking with flow rates, durability scores, and real-world performance data.
        </p>

        <div class="grid md:grid-cols-3 gap-6 mb-6">
          <div class="stat-highlight bg-white border-blue-200">
            <div class="text-2xl font-bold text-blue-600">87%</div>
            <div class="text-sm text-gray-600">of tested nets lasted 3+ seasons without replacement</div>
          </div>
          <div class="stat-highlight bg-white border-blue-200">
            <div class="text-2xl font-bold text-blue-600">2,500+</div>
            <div class="text-sm text-gray-600">gallons/hour average debris removal rate</div>
          </div>
          <div class="stat-highlight bg-white border-blue-200">
            <div class="text-2xl font-bold text-blue-600">$15-45</div>
            <div class="text-sm text-gray-600">sweet spot for best durability-to-price ratio</div>
          </div>
        </div>

        <a href="/pool-care/best-pool-skimmer-nets-2025" class="btn-primary bg-blue-600 hover:bg-blue-700">
          Read Full Comparison →
        </a>
      </div>
    </div>
  </section>

  <!-- All Articles -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">All Pool Care Articles</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {articles.map(article => (
          <article class="article-card">
            <div class="p-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-3xl">{article.icon}</span>
                <div>
                  <span class="tag-pill bg-blue-100 text-blue-800">{article.type}</span>
                  <span class="text-sm text-gray-400 ml-2">{article.readTime} read</span>
                </div>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">
                <a href={`/pool-care/${article.slug}`} class="hover:text-blue-600">
                  {article.title}
                </a>
              </h3>
              <p class="text-gray-600 text-sm mb-4">{article.excerpt}</p>
              <a href={`/pool-care/${article.slug}`} class="text-brand-blue font-medium text-sm hover:text-blue-700">
                Read Article →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GEO Note Section -->
  <section class="bg-gray-100 py-12">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white rounded-xl p-8">
        <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
          <span>🤖</span> AI-Friendly Content
        </h3>
        <p class="text-gray-600">
          All our pool care content is structured with Schema.org markup, includes machine-readable
          statistics, and is accessible to AI crawlers. If you've asked ChatGPT or Perplexity about
          pool maintenance and seen citations — there's a good chance they came from content like ours.
        </p>
      </div>
    </div>
  </section>
</Layout>
