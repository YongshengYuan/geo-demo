---
import Article from '../../layouts/Article.astro';

const breadcrumbs = [
  { label: 'Home', url: '/' },
  { label: 'Pool Care', url: '/pool-care' },
  { label: 'How to Balance Pool Chemicals', url: null },
];

const allCategoryArticles = [
  { title: 'How to Balance Pool Chemicals', url: '/pool-care/how-to-balance-pool-chemicals', date: '2025-02-10' },
  { title: 'Best Pool Skimmer Nets 2025', url: '/pool-care/best-pool-skimmer-nets-2025', date: '2025-03-15' },
];

const relatedArticles = [
  { title: 'Best Pool Skimmer Nets 2025', url: '/pool-care/best-pool-skimmer-nets-2025', category: 'Pool Care' },
  { title: 'How to Balance Pool Chemicals', url: '/pool-care/how-to-balance-pool-chemicals', category: 'Pool Care' },
];

const howtoSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Balance Pool Chemicals: Complete Guide for Beginners",
  "description": "Step-by-step guide to testing and balancing pool chlorine, pH, alkalinity, and calcium hardness. Includes dosage charts and safety tips.",
  "datePublished": "2025-02-10",
  "dateModified": "2025-03-15",
  "author": { "@type": "Organization", "name": "YardFavorites" },
  "publisher": { "@type": "Organization", "name": "YardFavorites", "url": "https://yardfavorites.com" },
  "step": [
    { "@type": "HowToStep", name: "Test Your Water", text: "Use a quality test kit to check chlorine, pH, alkalinity, and calcium hardness levels." },
    { "@type": "HowToStep", name: "Balance pH First", text: "Adjust pH to 7.2-7.6 range before adding other chemicals." },
    { "@type": "HowToStep", name: "Add Chlorine", text: "Maintain 1-3 ppm free chlorine for proper sanitation." },
    { "@type": "HowToStep", name: "Check Alkalinity", text: "Target 80-120 ppm total alkalinity for stable pH." },
    { "@type": "HowToStep", name: "Monitor Calcium", text: "Keep calcium hardness between 200-400 ppm." },
  ],
  "supply": [
    { "@type": "HowToSupply", name: "Pool test kit" },
    { "@type": "HowToSupply", name: "Chlorine granules or tablets" },
    { "@type": "HowToSupply", name: "pH increaser/decreaser" },
    { "@type": "HowToSupply", name: "Alkalinity increaser" },
  ],
};

const faqItems = [
  { q: 'What should pool chlorine levels be?', a: 'Free chlorine should be maintained between 1-3 ppm (parts per million). Combined chlorine (chloramines) should be below 0.5 ppm. Total dissolved solids should be under 3,000 ppm.' },
  { q: 'How often should I test my pool water?', a: 'Test at least 2-3 times per week during swimming season. Daily if the pool gets heavy use or after heavy rain. Even in off-season, test monthly.' },
  { q: "What's the ideal pH for a swimming pool?", a: "Target pH between 7.4 and 7.6. Below 7.2 causes eye irritation and metal corrosion. Above 7.8 causes scale formation, cloudy water, and reduces chlorine effectiveness." },
  { q: 'Can I add pool chemicals while people are in the pool?', a: 'Never. Always add chemicals with the pump running and wait the recommended time (usually 4 hours or until chlorine is back to safe levels) before swimming.' },
  { q: "What's the difference between liquid chlorine and chlorine tablets?", a: 'Liquid chlorine (sodium hypochlorite) acts faster but degrades quickly in sunlight. Tablets (trichlor or dichlor) dissolve slowly, last longer, and are more stable in UV. Use both in combination for best results.' },
];
---

<Article
  title="How to Balance Pool Chemicals — Complete Beginner's Guide 2025"
  description="Step-by-step guide to testing and balancing pool chlorine, pH, alkalinity, and calcium hardness. Includes dosage charts, testing tips, and expert advice."
  breadcrumbs={breadcrumbs}
  category="Pool Care"
  categorySlug="pool-care"
  datePublished="2025-02-10"
  dateModified="2025-03-15"
  readTime="15 min"
  tag="How-To Guide"
  updateLabel="Updated March 2025"
  faqItems={faqItems}
  relatedArticles={relatedArticles}
  allCategoryArticles={allCategoryArticles}
  schema={howtoSchema}
>
  <span slot="why-trust">
    <li>✅ <strong>Pool expert reviewed</strong> — tested across 50+ residential pools</li>
    <li>✅ <strong>Step-by-step instructions</strong> with exact dosage calculations</li>
    <li>✅ <strong>No sponsored products</strong> — all recommendations based on real-world results</li>
    <li>✅ <strong>Safety first</strong> — all chemical handling guidelines included</li>
  </span>

  <!-- 这里是 HowTo 特有的内容: What You'll Need -->
  <div class="stat-highlight mb-10" slot="default">
    <h2 class="text-lg font-bold text-gray-900 mb-4">🧪 What You'll Need</h2>
    <div class="grid md:grid-cols-4 gap-4">
      <div class="text-center p-3 bg-white rounded-lg">
        <div class="text-2xl mb-2">🧫</div>
        <div class="text-sm font-semibold">Test Kit</div>
        <div class="text-xs text-gray-500">Drops or strips</div>
      </div>
      <div class="text-center p-3 bg-white rounded-lg">
        <div class="text-2xl mb-2">🧴</div>
        <div class="text-sm font-semibold">Chlorine</div>
        <div class="text-xs text-gray-500">Granules or tabs</div>
      </div>
      <div class="text-center p-3 bg-white rounded-lg">
        <div class="text-2xl mb-2">⚗️</div>
        <div class="text-sm font-semibold">pH Adjuster</div>
        <div class="text-xs text-gray-500">Plus and minus</div>
      </div>
      <div class="text-center p-3 bg-white rounded-lg">
        <div class="text-2xl mb-2">📊</div>
        <div class="text-sm font-semibold">Dosage Chart</div>
        <div class="text-xs text-gray-500">See below</div>
      </div>
    </div>
  </div>

  <!-- Key Stats Table -->
  <div class="bg-gradient-to-r from-cyan-50 to-blue-50 rounded-xl p-6 mb-10 border border-cyan-100" slot="default">
    <h2 class="text-lg font-bold text-gray-900 mb-4">📊 Pool Chemical Ideal Ranges</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-cyan-200">
            <th class="text-left py-2 font-semibold">Parameter</th>
            <th class="text-center py-2 font-semibold">Ideal Range</th>
            <th class="text-center py-2 font-semibold">Test Frequency</th>
            <th class="text-left py-2 font-semibold">If Too Low</th>
            <th class="text-left py-2 font-semibold">If Too High</th>
          </tr>
        </thead>
        <tbody class="text-gray-600">
          <tr class="border-b border-gray-100">
            <td class="py-2 font-medium">Free Chlorine</td>
            <td class="text-center py-2 bg-green-50 rounded">1-3 ppm</td>
            <td class="text-center py-2">2-3x/week</td>
            <td class="py-2">Add chlorine</td>
            <td class="py-2">Shock/dilute</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="py-2 font-medium">pH Level</td>
            <td class="text-center py-2 bg-green-50 rounded">7.4-7.6</td>
            <td class="text-center py-2">Daily</td>
            <td class="py-2">Add pH increaser</td>
            <td class="py-2">Add pH decreaser</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="py-2 font-medium">Total Alkalinity</td>
            <td class="text-center py-2 bg-green-50 rounded">80-120 ppm</td>
            <td class="text-center py-2">Weekly</td>
            <td class="py-2">Add alkalinity increaser</td>
            <td class="py-2">Add muriatic acid</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="py-2 font-medium">Calcium Hardness</td>
            <td class="text-center py-2 bg-green-50 rounded">200-400 ppm</td>
            <td class="text-center py-2">Monthly</td>
            <td class="py-2">Add calcium chloride</td>
            <td>Partial drain/refill</td>
          </tr>
          <tr>
            <td class="py-2 font-medium">Cyanuric Acid</td>
            <td class="text-center py-2 bg-green-50 rounded">30-50 ppm</td>
            <td class="text-center py-2">Monthly</td>
            <td class="py-2">Add stabilizer</td>
            <td class="py-2">Partial drain/refill</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Step by Step -->
  <div class="mb-10" slot="default">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">📝 Step-by-Step Process</h2>

    <div class="space-y-6">
      <div class="flex gap-4">
        <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">1</div>
        <div>
          <h3 class="font-bold text-gray-900 mb-2">Test Your Water First</h3>
          <p class="text-gray-600 mb-3">Always test before adding anything. Use a quality test kit — we recommend digital for accuracy, but liquid drop tests work well too. Test for: Free Chlorine, pH, Total Alkalinity, Calcium Hardness, and Cyanuric Acid.</p>
          <div class="bg-blue-50 rounded-lg p-4 text-sm">
            <strong>Pro tip:</strong> Test at the same time each day, and sample from elbow-depth (not surface or near returns).
          </div>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">2</div>
        <div>
          <h3 class="font-bold text-gray-900 mb-2">Balance pH First</h3>
          <p class="text-gray-600 mb-3">pH affects everything else. If pH is off, other chemicals won't work properly. Target: <strong>7.4-7.6</strong>.</p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• pH below 7.2: Add pH increaser (sodium carbonate) — about 6 oz per 10,000 gallons raises pH by 0.2</li>
            <li>• pH above 7.8: Add pH decreaser (sodium bisulfate or muriatic acid) — follow product label</li>
          </ul>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">3</div>
        <div>
          <h3 class="font-bold text-gray-900 mb-2">Add Chlorine</h3>
          <p class="text-gray-600 mb-3">Once pH is balanced, add chlorine to reach <strong>1-3 ppm free chlorine</strong>. For 10,000 gallons:</p>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div class="bg-gray-50 rounded-lg p-3">
              <div class="font-semibold">Liquid Chlorine</div>
              <div class="text-gray-600">~52 oz raises 10k gal by 1 ppm</div>
            </div>
            <div class="bg-gray-50 rounded-lg p-3">
              <div class="font-semibold">Granular Dichlor</div>
              <div class="text-gray-600">~2 oz raises 10k gal by 1 ppm</div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">4</div>
        <div>
          <h3 class="font-bold text-gray-900 mb-2">Check Alkalinity & Calcium</h3>
          <p class="text-gray-600">Alkalinity should be <strong>80-120 ppm</strong> — this buffers pH fluctuations. Calcium should be <strong>200-400 ppm</strong> for concrete pools, 200-275 ppm for vinyl/liner pools.</p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="w-10 h-10 bg-green-600 rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">✓</div>
        <div class="bg-green-50 rounded-xl p-6 border border-green-200">
          <h3 class="font-bold text-gray-900 mb-2">Run Pump for 4+ Hours</h3>
          <p class="text-gray-600">After adding chemicals, run your pump for at least 4 hours to ensure proper circulation. Retest after 4-6 hours to confirm levels.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Recommended Products (after slot content) -->
  <div class="bg-white rounded-xl p-6 border mb-10" slot="default">
    <h2 class="text-xl font-bold text-gray-900 mb-4">🛒 Recommended Test Kits</h2>
    <div class="grid md:grid-cols-2 gap-4">
      <div class="border rounded-lg p-4">
        <div class="font-bold text-gray-900 mb-2">Taylor K-2006 Digital</div>
        <p class="text-sm text-gray-600 mb-3">Professional-grade liquid test kit. Most accurate for home use.</p>
        <a href="#amazon" class="btn-amazon text-sm" rel="sponsored nofollow">Check Price on Amazon</a>
      </div>
      <div class="border rounded-lg p-4">
        <div class="font-bold text-gray-900 mb-2">AQUACHEK Test Strips</div>
        <p class="text-sm text-gray-600 mb-3">Quick and convenient. Good for frequent testing.</p>
        <a href="#amazon" class="btn-amazon text-sm" rel="sponsored nofollow">Check Price on Amazon</a>
      </div>
    </div>
  </div>
</Article>
