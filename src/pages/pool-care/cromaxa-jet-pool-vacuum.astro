];

const topPick = {
  name: 'Cromaxa Jet Pool Vacuum',
  price: '$24.79',
  rating: 4.5,
  pros: [
    'No battery or electricity needed - garden hose powered',
    '4-section telescopic pole extends to 59" / 150cm',
    'Works with above ground pools, spas, hot tubs & ponds',
