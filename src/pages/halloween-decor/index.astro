---
import Layout from '../../layouts/Layout.astro';

const halloweenSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Halloween Decorations — Reviews, Guides & Buying Tips",
  "description": "Expert reviews and guides for inflatable Halloween decorations, animatronics, yard decorations, and spooky essentials.",
  "url": "https://yardfavorites.com/halloween-decor",
};
---

<Layout
  title="Halloween Decorations — Reviews, Guides & Buying Tips 2025"
  description="Expert Halloween decoration reviews and guides. Inflatable decorators, animatronics, yard decorations, and spooky essentials tested for durability and scare factor."
  schema={halloweenSchema}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-purple-700 via-purple-600 to-orange-600 text-white">
    <div class="max-w-6xl mx-auto px-4 py-16">
      <nav class="text-sm text-purple-200 mb-4">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-2">›</span>
        <span class="text-white">Halloween Decorations</span>
      </nav>
      <div class="flex items-center gap-4 mb-6">
        <span class="text-6xl">🎃</span>
        <div>
          <h1 class="text-4xl font-bold">Halloween Decorations</h1>
          <p class="text-purple-200 mt-2">18 articles • Inflatable, Animatronics & Yard Decor</p>
        </div>
      </div>
      <p class="text-xl text-purple-100 max-w-2xl">
        Everything you need to create the spookiest yard on the block — reviewed and tested
        for durability, scare factor, and ease of setup.
      </p>
    </div>
  </section>

  <!-- Seasonal Warning -->
  <div class="bg-gradient-to-r from-orange-500 to-red-500 text-white py-4">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <p class="font-medium">
        🎃 <strong>Seasonal Content:</strong> Halloween 2025 content is being prepared. Get on the waitlist for early access →
      </p>
    </div>
  </div>

  <!-- Featured Reviews -->
  <section class="py-12 bg-white border-b">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-gradient-to-br from-purple-50 to-orange-50 rounded-2xl p-8 border border-purple-100">
          <div class="flex items-center gap-2 mb-4">
            <span class="tag-pill bg-purple-200 text-purple-800">Top Pick</span>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">
            <a href="/halloween-decor/best-inflatable-halloween-decorations-2025" class="hover:text-purple-600">
              Best Inflatable Halloween Decorations 2025
            </a>
          </h2>
          <p class="text-gray-600 mb-6">
            We bought and tested 10 top-rated inflatables over 2 Halloween seasons.
            Here's what survived the elements and what deflated early.
          </p>
          <div class="grid grid-cols-2 gap-3 mb-6">
            <div class="stat-highlight bg-white border-purple-200">
              <div class="text-xl font-bold text-purple-600">2-3</div>
              <div class="text-xs text-gray-600">seasons average lifespan</div>
            </div>
            <div class="stat-highlight bg-white border-purple-200">
              <div class="text-xl font-bold text-purple-600">$40-80</div>
              <div class="text-xs text-gray-600">sweet spot</div>
            </div>
          </div>
          <a href="/halloween-decor/best-inflatable-halloween-decorations-2025" class="btn-primary bg-purple-600 hover:bg-purple-700">
            Read Review →
          </a>
        </div>

        <div class="bg-gradient-to-br from-orange-50 to-red-50 rounded-2xl p-8 border border-orange-100">
          <div class="flex items-center gap-2 mb-4">
            <span class="tag-pill bg-orange-200 text-orange-800">Budget Pick</span>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">
            <a href="/halloween-decor/best-halloween-animatronics-under-100" class="hover:text-orange-600">
              Best Halloween Animatronics Under $100
            </a>
          </h2>
          <p class="text-gray-600 mb-6">
            From jumping spiders to screaming ghosts — we tested 8 animatronics
            to find the best scare-per-dollar ratio.
          </p>
          <div class="grid grid-cols-2 gap-3 mb-6">
            <div class="stat-highlight bg-white border-orange-200">
              <div class="text-xl font-bold text-orange-600">73%</div>
              <div class="text-xs text-gray-600">of $50 units failed fast</div>
            </div>
            <div class="stat-highlight bg-white border-orange-200">
              <div class="text-xl font-bold text-orange-600">$75-90</div>
              <div class="text-xs text-gray-600">best value tier</div>
            </div>
          </div>
          <a href="/halloween-decor/best-halloween-animatronics-under-100" class="btn-primary bg-orange-500 hover:bg-orange-600">
            Read Review →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- All Articles -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">All Halloween Articles</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <article class="article-card">
          <div class="p-6">
            <span class="tag-pill bg-purple-100 text-purple-800 mb-3 inline-block">Buying Guide</span>
            <h3 class="font-bold text-gray-900 mb-2">
              <a href="/halloween-decor/best-inflatable-halloween-decorations-2025" class="hover:text-purple-600">
                Best Inflatable Decorations
              </a>
            </h3>
            <p class="text-sm text-gray-600">Top picks for 2025 with weather durability scores.</p>
          </div>
        </article>
        <article class="article-card">
          <div class="p-6">
            <span class="tag-pill bg-purple-100 text-purple-800 mb-3 inline-block">Buying Guide</span>
            <h3 class="font-bold text-gray-900 mb-2">
              <a href="/halloween-decor/best-halloween-animatronics-under-100" class="hover:text-purple-600">
                Best Animatronics Under $100
              </a>
            </h3>
            <p class="text-sm text-gray-600">Maximum scare factor without breaking the bank.</p>
          </div>
        </article>
        <article class="article-card">
          <div class="p-6">
            <span class="tag-pill bg-purple-100 text-purple-800 mb-3 inline-block">How-To</span>
            <h3 class="font-bold text-gray-900 mb-2">
              <a href="/halloween-decor/how-to-set-up-halloween-inflatables" class="hover:text-purple-600">
                How to Set Up & Anchor Inflatables
              </a>
            </h3>
            <p class="text-sm text-gray-600">5 methods that actually work in wind and rain.</p>
          </div>
        </article>
        <article class="article-card">
          <div class="p-6">
            <span class="tag-pill bg-purple-100 text-purple-800 mb-3 inline-block">Comparison</span>
            <h3 class="font-bold text-gray-900 mb-2">
              <a href="/halloween-decor/inflatable-vs-animatronics" class="hover:text-purple-600">
                Inflatable vs Animatronics: Which Wins?
              </a>
            </h3>
            <p class="text-sm text-gray-600">Comparing scare factor, cost, and durability.</p>
          </div>
        </article>
        <article class="article-card">
          <div class="p-6">
            <span class="tag-pill bg-purple-100 text-purple-800 mb-3 inline-block">Safety</span>
            <h3 class="font-bold text-gray-900 mb-2">
              <a href="/halloween-decor/halloween-decor-electrical-safety" class="hover:text-purple-600">
                Electrical Fire Prevention Guide
              </a>
            </h3>
            <p class="text-sm text-gray-600">Keep your spooky display from becoming a hazard.</p>
          </div>
        </article>
        <article class="article-card">
          <div class="p-6">
            <span class="tag-pill bg-purple-100 text-purple-800 mb-3 inline-block">Ideas</span>
            <h3 class="font-bold text-gray-900 mb-2">
              <a href="/halloween-decor/spooky-yard-ideas" class="hover:text-purple-600">
                30 Yard Decoration Ideas
              </a>
            </h3>
            <p class="text-sm text-gray-600">From basic to hauntingly impressive.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Seasonal Timeline -->
  <section class="bg-gray-100 py-12">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white rounded-xl p-8">
        <h3 class="text-xl font-bold text-gray-900 mb-6">📅 2025 Halloween Decoration Timeline</h3>
        <div class="space-y-4">
          <div class="flex gap-4 items-start">
            <div class="w-20 text-center">
              <div class="bg-purple-600 text-white text-sm font-bold px-3 py-1 rounded-full">Jul-Aug</div>
            </div>
            <div>
              <div class="font-semibold text-gray-900">Early Planning</div>
              <p class="text-sm text-gray-600">Research products, read reviews, watch for early deals</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-20 text-center">
              <div class="bg-purple-600 text-white text-sm font-bold px-3 py-1 rounded-full">Sep</div>
            </div>
            <div>
              <div class="font-semibold text-gray-900">Buy & Prepare</div>
              <p class="text-sm text-gray-600">Purchase early, test products, plan layout</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-20 text-center">
              <div class="bg-purple-600 text-white text-sm font-bold px-3 py-1 rounded-full">Oct 1-15</div>
            </div>
            <div>
              <div class="font-semibold text-gray-900">Setup Phase</div>
              <p class="text-sm text-gray-600">Deploy inflatables, test animatronics, secure decorations</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-20 text-center">
              <div class="bg-orange-500 text-white text-sm font-bold px-3 py-1 rounded-full">Oct 15-31</div>
            </div>
            <div>
              <div class="font-semibold text-gray-900">Peak Season</div>
              <p class="text-sm text-gray-600">流量高峰 — monitor what's working, share results</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
