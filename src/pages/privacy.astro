---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Privacy Policy"
  description="YardFavorites Privacy Policy - how we collect, use, and protect your data."
>
  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4 prose prose-lg">
      <h1>Privacy Policy</h1>
      <p><strong>Last updated:</strong> March 2025</p>
      <h2>Information We Collect</h2>
      <p>
        We do not collect personal information. Our site is informational only
        and does not require account creation or login.
      </p>
      <h2>Cookies</h2>
      <p>
        We use minimal essential cookies for site functionality only. We do not
        use advertising cookies or tracking pixels.
      </p>
      <h2>Third-Party Services</h2>
      <p>
        We use Cloudflare for site security and analytics that respect privacy.
        Amazon affiliate links are served through the Amazon Associates program.
      </p>
      <h2>Contact</h2>
      <p>Questions about privacy? Email <strong>hello@yardfavorites.com</strong></p>
    </div>
  </section>
</Layout>
